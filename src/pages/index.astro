---
import Layout from "../layouts/Layout.astro";
import ChartsSection from "../components/ChartsSection.astro";
import { translations, defaultLocale } from "../i18n/translations";

const t = translations[defaultLocale].home;
---

<Layout title="eTariffs">
  <div class="grid grid-cols-1 gap-6">
    <div class="rounded-xl border border-gray-200 dark:border-gray-800 p-4">
      <h3
        class="text-sm font-semibold text-gray-600 dark:text-gray-400 mb-4"
        data-i18n="home.whatIsTitle"
      >
        {t.whatIsTitle}
      </h3>
      <p
        class="text-sm text-gray-500 dark:text-gray-400"
        data-i18n="home.whatIsBody"
      >
        {t.whatIsBody}
      </p>
    </div>
    <ChartsSection />
  </div>
</Layout>
