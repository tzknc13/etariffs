---
interface Props {
  title?: string;
  colSpan?: string;
}
const { title, colSpan } = Astro.props;
---

<div class=` ${colSpan} rounded-xl border border-site-white bg-site-white/50 overflow-hidden`>
  {title && (
    <div class="px-4 py-3 border-b border-gray-200">
      <h3 class="text-sm font-semibold text-site-text">{title}</h3>
    </div>
  )}
  <div class="p-4">
    <slot />
  </div>
</div>
