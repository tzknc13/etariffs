---
interface Props {
  title?: string;
  colSpan?: string;
  logo_url?: string;
  isThin?: boolean;
  isMoon?: boolean;
}
const { title, colSpan, logo_url, isThin = false, isMoon = false } = Astro.props;
---

<div class={`card-frame relative ${colSpan} rounded-xl overflow-hidden`}>
  {
    title && (
      <div
        class={`px-4 border-b flex gap-2 items-center ${isThin ? "py-1" : "py-3"} `}
        style="border-color: rgba(0,229,160,0.12);"
      >
        {logo_url && (
          <img
            src={logo_url}
            alt={`${title} logo`}
            class="w-20 h-6 object-contain"
          />
        )}
        <h3
          class="text-xs font-semibold tracking-widest uppercase"
          style="color: #00e5a0;"
        >
          {title}
        </h3>
        {isMoon && <div class="moon" />}
      </div>
    )
  }
  <div class="p-2 lg:p-4">
    <slot />
  </div>
</div>

<style>
  .card-frame {
    background: rgba(13, 19, 24, 0.72);
    border: 1px solid rgba(0, 229, 160, 0.18);
    backdrop-filter: blur(20px);
    box-shadow:
      0 0 40px rgba(0, 229, 160, 0.08),
      0 20px 40px rgba(0, 0, 0, 0.4);
  }
  .card-frame::before,
  .card-frame::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border-color: #00e5a0;
    border-style: solid;
    opacity: 0.6;
  }
  .card-frame::before {
    top: -1px;
    left: -1px;
    border-width: 2px 0 0 2px;
    border-radius: 12px 0 0 0;
  }
  .card-frame::after {
    bottom: -1px;
    right: -1px;
    border-width: 0 2px 2px 0;
    border-radius: 0 0 12px 0;
  }
  .moon {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: transparent;
    box-shadow: 2px -1px 0 0.5px #808080 inset;
  }
</style>
