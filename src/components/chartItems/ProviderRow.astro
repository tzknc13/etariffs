---
interface Props {
  label: string;
  price: number;
  maxPrice: number;
  monthlyFee: number;
}

const { label, price, maxPrice, monthlyFee } = Astro.props;
const barWidth = Math.round((price / maxPrice) * 100);
---

<div class="provider-row" data-monthly-fee={monthlyFee}>
  <div class="flex justify-start items-baseline center gap-3 py-1.5">
    <!-- <span class="bg-site-white text-md text-green-800">{monthlyFee}</span> -->
    <span class="text-xs text-gray-800">{label}</span>
  </div>
  <div class="flex items-center gap-3 py-1.5">
    <!-- icon -->
    <div class="w-7 h-7 shrink-0 rounded-full bg-gray-200 border border-gray-300">
    </div>
    <!-- graph -->
    <div class="flex-1">

      <div class="flex-1 h-2 bg-gray-100 rounded overflow-hidden">
        <div class="h-full bg-indigo-500 rounded" style={`width: ${barWidth}%`} />
      </div>
      <!-- <div class="flex-1 h-2 bg-gray-100 rounded overflow-hidden">
        <div class="h-full bg-indigo-500 rounded" style={`width: ${barWidth}%`} />
      </div> -->
    </div>
      
    <span class="w-12 shrink-0 text-right text-xs font-medium text-gray-900">
      €{price.toFixed(2)}
    </span>
  </div>
</div>
