---
import PercentageBar from './PercentageBar.astro';

interface Props {
  label: string;
  price: number;
  maxPrice: number;
  monthlyFee: number;
  logo_url: string;
}

const { label, price, maxPrice, monthlyFee, logo_url } = Astro.props;
---

<div class="provider-row" data-monthly-fee={monthlyFee}>
  <div class="flex justify-start items-baseline center gap-3 py-1.5">
    <span class="text-xs" style="color: #4a6070;">{label}</span>
  </div>
  <div class="flex items-center gap-3 py-1.5">
    <div class="w-7 h-7 shrink-0 rounded-full border" style="background: #1c2830; border-color: rgba(0,229,160,0.2);">
      <img src={logo_url} alt={label} class="w-full h-full object-contain" />
    </div>
    <div class="flex-1">
      <PercentageBar value={price} max={maxPrice} />
    </div>
    <span class="w-12 shrink-0 text-right text-xs font-medium" style="color: #e8f0ec;">
      czk {price.toFixed(2)}
    </span>
  </div>
</div>
