---
interface Props {
  label: string;
  price: number;
  maxPrice: number;
}

const { label, price, maxPrice } = Astro.props;
const barWidth = Math.round((price / maxPrice) * 100);
---

<div class="flex items-center gap-3 py-1.5">
  <span class="w-36 shrink-0 text-xs text-gray-700 dark:text-gray-300 truncate">{label}</span>
</div>
<div class="flex items-center gap-3 py-1.5">
  <div class="w-7 h-7 shrink-0 rounded-full bg-gray-200 dark:bg-gray-700 border border-gray-300 dark:border-gray-600"></div>
  <div class="flex-1 h-4 bg-gray-100 dark:bg-gray-800 rounded overflow-hidden">
    <div
      class="h-full bg-indigo-500 rounded"
      style={`width: ${barWidth}%`}
    />
  </div>
  <span class="w-12 shrink-0 text-right text-xs font-medium text-gray-900 dark:text-white">
    €{price.toFixed(2)}
  </span>
</div>
