---
import PercentageBar from "./PercentageBar.astro";
import PercentageCircle from "./PercentageCircle.astro";
import KilowattsRange from "./KilowattsRange.astro";

interface Props {
  label: string;
  prices: {
    AC: { price: number; kwFrom: number; kwTo: number };
    DC: { price: number; kwFrom: number; kwTo: number };
    UFC: { price: number; kwFrom: number; kwTo: number };
  };
  maxPrice: {
    AC: number;
    DC: number;
    UFC: number;
  };
  monthlyFee: number;
  logo_url: string;
}

const { label, prices, maxPrice, monthlyFee, logo_url } = Astro.props;
---

<div data-monthly-fee={monthlyFee}>
  <div class="grid grid-cols-4">
    <div class="col-span-1 borderline rowcell rowcell-first">
      {
        logo_url && (
          <img
            src={logo_url}
            alt={`${label} logo`}
            class="w-10 h-6 object-contain"
          />
        )
      }
      <div>
        <span class="monetary-value monthly-fee-value">
          {monthlyFee}
        </span>
        <span class="czk-currency"> czk </span>
      </div>
    </div>
    <div class="col-span-1 borderline rowcell">
      <KilowattsRange from={prices.AC.kwFrom} to={prices.AC.kwTo} label="kW" />
      <span class="monetary-value">
        {prices.AC.price}
      </span>
      <span class="czk-currency"> czk/kWh </span>
      <PercentageBar value={prices.AC.price} max={maxPrice.AC} type="bar" />
      <!-- <PercentageCircle value={prices.AC.price} max={maxPrice.AC}/> -->
    </div>
    <div class="col-span-1 borderline rowcell">
      <KilowattsRange from={prices.DC.kwFrom} to={prices.DC.kwTo} label="kW" />
      <span class="monetary-value">
        {prices.DC.price}
      </span>
      <span class="czk-currency"> czk/kWh </span>
      <PercentageBar value={prices.DC.price} max={maxPrice.DC} type="dc" />
      <!-- <PercentageCircle value={prices.DC.price} max={maxPrice.DC}/> -->
    </div>
    <div class="col-span-1 rowcell">
      <KilowattsRange from={prices.UFC.kwFrom} to={prices.UFC.kwTo} label="kW" />
      <span class="monetary-value">
        {prices.UFC.price}
      </span>
      <span class="czk-currency"> czk/kWh </span>
      <PercentageBar value={prices.UFC.price} max={maxPrice.UFC} type="ufc" />
      <!-- <PercentageCircle value={prices.UFC.price} max={maxPrice.UFC}/> -->
    </div>
  </div>
</div>

<style>
  .borderline {
    border-right: 1px solid rgba(0, 229, 160, 0.12);
  }
  .rowcell {
    /* display: flex; */
    /* flex-direction: column; */
    display: grid;
    align-items: center;
    align-content: baseline;
    padding: 0.3rem;
    /* text-align: center; */
  }
  .rowcell-first {
    display: flex;
    align-items: center;
    justify-content: space-around;
    align-content: baseline;
    padding: 0.3rem;
    /* text-align: center; */
  }
  .czk-currency {
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.6);
    margin-left: 2px;
  }
  .monetary-value {
    font-size: 0.875rem;
    font-weight: 600;
  }

  .monthly-fee-value {
    /* color: rgba(255, 255, 255, 0.8); */
    font-size: 1.1rem;
  }
</style>
