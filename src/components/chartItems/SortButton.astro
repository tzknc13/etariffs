---
interface Props {
  label: string;
  sortKey: string;
}

const { label, sortKey } = Astro.props;
---

<button
  class="sort-btn flex items-center justify-center gap-1 w-full cursor-pointer select-none"
  data-sort-key={sortKey}
  data-sort-dir="none"
  aria-label={`Sort by ${label}`}
>
  <span>{label}</span>
  <svg
    class="sort-arrow w-3 h-3 shrink-0 transition-transform duration-200"
    viewBox="0 0 10 10"
    fill="currentColor"
    aria-hidden="true"
  >
    <!-- neutral: two small chevrons stacked -->
    <path class="arrow-up" d="M5 3 L2 6.5 L8 6.5 Z" opacity="0.3" />
    <path class="arrow-down" d="M5 7 L2 3.5 L8 3.5 Z" opacity="0.3" />
  </svg>
</button>

<script>
  document.querySelectorAll<HTMLButtonElement>(".sort-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      const current = btn.dataset.sortDir ?? "none";
      const next =
        current === "none" || current === "desc" ? "asc" : "desc";

      // reset all other buttons
      document
        .querySelectorAll<HTMLButtonElement>(".sort-btn")
        .forEach((b) => {
          b.dataset.sortDir = "none";
          b.classList.remove("sort-btn--active");
          const up = b.querySelector<SVGPathElement>(".arrow-up");
          const down = b.querySelector<SVGPathElement>(".arrow-down");
          if (up) up.style.opacity = "0.3";
          if (down) down.style.opacity = "0.3";
        });

      btn.dataset.sortDir = next;
      btn.classList.add("sort-btn--active");
      const up = btn.querySelector<SVGPathElement>(".arrow-up");
      const down = btn.querySelector<SVGPathElement>(".arrow-down");

      if (next === "asc") {
        if (up) up.style.opacity = "1";
        if (down) down.style.opacity = "0.3";
      } else {
        if (up) up.style.opacity = "0.3";
        if (down) down.style.opacity = "1";
      }

      btn.dispatchEvent(
        new CustomEvent("sort", {
          detail: { key: btn.dataset.sortKey, dir: next },
          bubbles: true,
        })
      );
    });
  });
</script>
<style>
  .sort-btn {
    border-radius: 8px;
    border: 1px solid rgba(0, 229, 160, 0.18);
    backdrop-filter: blur(20px);
    box-shadow:
      0 0 40px rgba(0, 229, 160, 0.08),
      0 20px 40px rgba(0, 0, 0, 0.4);
    transition: border-color 0.2s, background-color 0.2s;
  }

  .sort-btn--active {
    border-color: rgba(0, 229, 160, 0.7);
    background-color: rgba(0, 229, 160, 0.08);
    color: #00e5a0;
  }
</style>