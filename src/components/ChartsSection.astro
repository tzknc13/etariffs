---
import providersData from "../data/providers.json";
import { translations, defaultLocale } from "../i18n/translations";
import ProviderRow from "./chartItems/ProviderRow.astro";
import CombinedProviderRow from "./chartItems/CombinedProviderRow.astro";
import Card from "./Card.astro";
import FeeSlider from "./chartItems/FeeSlider.astro";
import SortButton from "./chartItems/SortButton.astro";

// prepare the tarifs raw data
// on server, not client

const t = translations[defaultLocale].home;
const tariffs = Object.values(providersData.providers).flat();
const maxFee = Math.max(...tariffs.map((t) => t.monthlyFee));

const allTariffs = tariffs.map((t) => ({
  label: t.name,
  priceAC: t.prices.AC.price,
  priceDC: t.prices.DC.price,
  priceUFC: t.prices.UFC.price,
  prices: {
    AC: { price: t.prices.AC.price },
    DC: { price: t.prices.DC.price },
    UFC: { price: t.prices.UFC.price },
  },
  monthlyFee: t.monthlyFee,
  logo_url: t.logo_url,
}));

const maxPrices = {
  AC: Math.max(...tariffs.map((t) => t.prices.AC.price)),
  DC: Math.max(...tariffs.map((t) => t.prices.DC.price)),
  UFC: Math.max(...tariffs.map((t) => t.prices.UFC.price)),
};
---

<div
  id="charts-section"
  data-tariffs={JSON.stringify(allTariffs)}
  data-max-fee={maxFee}
  class="grid grid-cols-5 gap-6 items-start"
>
  <!-- Slider -->
  <FeeSlider maxFee={maxFee} colSpan="col-span-1" />

  <!-- Charts -->

  <div class="col-span-4 grid grid-cols-4 gap-6 text-center">
    <SortButton label="Fee/mth." sortKey="monthlyFee" />
    <SortButton label="AC" sortKey="AC" />
    <SortButton label="DC" sortKey="DC" />
    <SortButton label="UFC" sortKey="UFC" />

    <div id="sort-container" class="col-span-4 flex flex-col gap-6">
      {
        allTariffs.map((t) => (
          <div
            data-sort-item
            data-fee={t.monthlyFee}
            data-ac={t.priceAC}
            data-dc={t.priceDC}
            data-ufc={t.priceUFC}
          >
            <Card title={t.label} logo_url={t.logo_url} colSpan="w-full">
              <CombinedProviderRow
                label={t.label}
                prices={t.prices}
                maxPrice={maxPrices}
                monthlyFee={t.monthlyFee}
                logo_url={t.logo_url}
              />
            </Card>
          </div>
        ))
      }
    </div>
  </div>

  <!-- <Card title={t.acPrice} colSpan="col-span-2"> (unused)
    {
      tariffsByAC.map((tariff) => (
        <ProviderRow
          label={tariff.label}
          price={tariff.priceAC}
          maxPrice={maxPriceAC}
          monthlyFee={tariff.monthlyFee}
          logo_url={tariff.logo_url}
        />
      ))
    }
  </Card>

  <Card title={t.dcPrice} colSpan="col-span-2">
    {
      tariffsByDC.map((tariff) => (
        <ProviderRow
          label={tariff.label}
          price={tariff.priceDC}
          maxPrice={maxPriceDC}
          monthlyFee={tariff.monthlyFee}
          logo_url={tariff.logo_url}
        />
      ))
    }
  </Card> -->
</div>

<script>
  const keyMap: Record<string, string> = {
    monthlyFee: "fee",
    AC: "ac",
    DC: "dc",
    UFC: "ufc",
  };

  function sortItems(dataKey: string, dir: "asc" | "desc") {
    const container = document.getElementById("sort-container");
    if (!container) return;
    const items = Array.from(
      container.querySelectorAll<HTMLElement>("[data-sort-item]")
    );
    items.sort((a, b) => {
      const av = parseFloat(a.dataset[dataKey] ?? "0");
      const bv = parseFloat(b.dataset[dataKey] ?? "0");
      return dir === "asc" ? av - bv : bv - av;
    });
    items.forEach((item) => container.appendChild(item));
  }

  function setButtonState(
    btn: HTMLElement,
    dir: "asc" | "desc" | "none"
  ) {
    btn.dataset.sortDir = dir;
    const up = btn.querySelector<SVGPathElement>(".arrow-up");
    const down = btn.querySelector<SVGPathElement>(".arrow-down");
    if (up) up.style.opacity = dir === "asc" ? "1" : "0.3";
    if (down) down.style.opacity = dir === "desc" ? "1" : "0.3";
  }

  // Default: sort by DC ascending
  const dcBtn = document.querySelector<HTMLElement>('[data-sort-key="DC"]');
  if (dcBtn) setButtonState(dcBtn, "asc");
  sortItems("dc", "asc");

  document.addEventListener("sort", (e: Event) => {
    const { key, dir } = (
      e as CustomEvent<{ key: string; dir: "asc" | "desc" }>
    ).detail;
    sortItems(keyMap[key] ?? key.toLowerCase(), dir);
  });
</script>
