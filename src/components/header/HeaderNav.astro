---
const currentPath = Astro.url.pathname;

interface NavItem {
  label: string;
  i18nKey: string;
  href: string;
  disabled?: boolean;
}

interface Props {
  navItems: NavItem[];
}

const { navItems } = Astro.props;
---

<nav class="flex items-center gap-6">
  {navItems.map(({ label, i18nKey, href, disabled }) => (
    disabled
      ? <span
          class="text-md px-3 py-1.5 rounded-md border border-transparent text-site-muted opacity-40 cursor-not-allowed"
          data-i18n={i18nKey}
        >{label}</span>
      : <a
          class={`text-md px-3 py-1.5 rounded-md transition-colors ${currentPath === href ? 'text-site-link' : 'text-site-muted hover:text-site-text'}`}
          style={currentPath === href ? 'background: rgba(0,229,160,0.1); border: 1px solid rgba(0,229,160,0.2);' : 'border: 1px solid transparent;'}
          data-i18n={i18nKey}
          href={href}
        >{label}</a>
  ))}
</nav>
