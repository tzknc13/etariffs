---
import { translations, defaultLocale } from '../../i18n/translations';
import Logo from '../Logo.astro';
import HeaderNav from './HeaderNav.astro';

const t = translations[defaultLocale];
---

<header class="my-12">
  <div class="mx-auto w-full max-w-8xl px-4 sm:px-6 lg:px-8 py-4 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <Logo size={40} />
      <h2 class="text-sm text-site-text mt-0.5" data-i18n="title">
        {t.titleLong}
      </h2>
    </div>

    <HeaderNav />

    <button
      id="lang-switcher"
      class="rounded-md px-3 py-1.5 text-sm font-medium transition-colors" style="border: 1px solid rgba(0,229,160,0.3); color: #00e5a0; background: rgba(0,229,160,0.05);" onmouseover="this.style.background='rgba(0,229,160,0.12)'" onmouseout="this.style.background='rgba(0,229,160,0.05)'"
      aria-label="Switch language"
      data-i18n="switchLanguage"
    >
      {t.switchLanguage}
    </button>
  </div>
</header>

<script>
  import { translations, locales, defaultLocale } from '../../i18n/translations';
  import type { Locale } from '../../i18n/translations';

  const STORAGE_KEY = 'etariffs-locale';

  function getSavedLocale(): Locale {
    const saved = localStorage.getItem(STORAGE_KEY);
    if (saved && (locales as readonly string[]).includes(saved)) {
      return saved as Locale;
    }
    const browser = navigator.language.split('-')[0];
    if ((locales as readonly string[]).includes(browser)) {
      return browser as Locale;
    }
    return defaultLocale;
  }

  function resolve(obj: Record<string, unknown>, path: string): string | undefined {
    const value = path.split('.').reduce<unknown>((cur, key) => (cur as Record<string, unknown>)?.[key], obj);
    return typeof value === 'string' ? value : undefined;
  }

  function applyLocale(locale: Locale) {
    const t = translations[locale] as unknown as Record<string, unknown>;
    document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
      const value = resolve(t, el.dataset.i18n!);
      if (value !== undefined) el.textContent = value;
    });
    localStorage.setItem(STORAGE_KEY, locale);
  }

  function toggleLocale(current: Locale): Locale {
    const idx = locales.indexOf(current);
    return locales[(idx + 1) % locales.length];
  }

  let currentLocale = getSavedLocale();
  applyLocale(currentLocale);

  document.getElementById('lang-switcher')?.addEventListener('click', () => {
    currentLocale = toggleLocale(currentLocale);
    applyLocale(currentLocale);
  });
</script>
